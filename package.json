{
  "name": "xbx.place",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "node scripts/dev-all.mjs",
    "supabase:watch": "node scripts/supabase-watch.mjs",
    "supabase:push": "npx supabase db push",
    "supabase:deploy": "bash scripts/supabase-push.sh",
    "supabase:discord-webhook": "node scripts/supabase-set-discord-webhook.mjs",
    "build:favicons": "python3 scripts/build-favicons.py && python3 scripts/build-og-image.py",
    "build:ia-map": "node scripts/build-ia-map.mjs",
    "build:x360db-catalog": "node scripts/build-x360db-catalog.mjs",
    "build:seo-pages": "node scripts/generate-seo-pages.mjs",
    "build:sitemap": "node scripts/generate-sitemap.mjs",
    "build:seo": "node scripts/build-seo.mjs",
    "build:data": "npm run build:x360db-catalog && npm run build:seo",
    "build": "npm run build:favicons && npm run build:data && tsc --noEmit && VITE_SEO_BUILT=1 vite build",
    "preview": "vite preview",
    "workers": "node scripts/manage-workers.mjs",
    "workers:deploy-all": "node scripts/manage-workers.mjs deploy-all",
    "workers:sync-secrets": "node scripts/manage-workers.mjs sync-secrets",
    "workers:waf": "node scripts/setup-download-waf.mjs",
    "ia-cookies": "node scripts/manage-ia-cookies.mjs",
    "test:ia-cookies": "node --test scripts/ia-cookie-pool.test.mjs"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@supabase/supabase-js": "^2.106.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
