# Internet Archive — cookie pool for build:ia-map and optional Vite default for the app.
# JSON array: [{"user":"you%40example.com","sig":"…"}, …]
# IA_COOKIE_POOL=[{"user":"…","sig":"…"}]
# VITE_IA_COOKIE_POOL=[{"user":"…","sig":"…"}]

# Supabase Auth (publishable keys only — safe for the static frontend):
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
