# Internet Archive pool (server/build only — never expose via Vite or the browser app).
# Paste from DevTools → archive.org cookies. Never commit real values. Prefer JSON pool (single line):

# IA_COOKIE_POOL=[{"user":"URL_ENCODED_logged-in-user","sig":"logged-in-sig"},...]
# Optional obfuscated form: base64(JSON string), optionally encoded multiple rounds.
# IA_COOKIE_POOL_B64=
# IA_COOKIE_B64_ROUNDS=1

# Or a single account:
# IA_LOGGED_IN_USER=
# IA_LOGGED_IN_SIG=

# Optional IA map builder:
# IA_MAP_LIMIT_IDENTIFIERS=3
# IA_MAP_FILTER_TO_MASTER=1

# Download auth gate (Cloudflare Worker — resolves URLs, does not proxy ROM bytes).
# vite.config.ts defaults to the deployed worker if unset.
# VITE_DOWNLOAD_PROXY_ORIGIN=https://xbx-place-download-proxy.youraccount.workers.dev

# Supabase Auth (publishable keys only — safe for the static frontend):
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Worker secrets (wrangler secret put — never expose in Vite):
#   npx wrangler secret put IA_COOKIE_POOL
# SUPABASE_URL=   (same project URL as VITE_SUPABASE_URL)
# SUPABASE_ANON_KEY=   (same as VITE_SUPABASE_ANON_KEY — required for signed-in downloads)
# SUPABASE_SERVICE_ROLE_KEY=   (guest download limits)
