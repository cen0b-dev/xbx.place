# Internet Archive cookie pool — managed via npm run ia-cookies (stored in Supabase ia_cookie_pool).
# Export archive.org cookies from a browser extension and paste into the manager.

# Optional IA map builder:
# IA_MAP_LIMIT_IDENTIFIERS=3
# IA_MAP_FILTER_TO_MASTER=1

# Supabase Auth (publishable keys only — safe for the static frontend):
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare Turnstile (publishable site key for the frontend):
# VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Server-side Supabase (build scripts, manage-workers, manage-ia-cookies, download-proxy workers):
# SUPABASE_URL=   (same project URL as VITE_SUPABASE_URL)
# SUPABASE_ANON_KEY=   (same as VITE_SUPABASE_ANON_KEY — required for signed-in downloads)
# SUPABASE_SERVICE_ROLE_KEY=   (guest download limits + ia_cookie_pool + worker_pool writes)
# SUPABASE_ACCESS_TOKEN=   (sbp_… personal access token — syncs worker-stats Edge Function secrets)

# Download proxy worker secrets (uploaded by npm run workers):
# DOWNLOAD_SIGNING_SECRET=   (auto-generated on first worker deploy if unset)
# TURNSTILE_SECRET_KEY=   (optional — pairs with VITE_TURNSTILE_SITE_KEY)

# Optional WAF setup for custom-domain worker routes (see scripts/setup-download-waf.mjs):
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# Discord webhook: set only in Supabase Edge Function secrets (never VITE_* or .env.local):
#   DISCORD_WEBHOOK_URL='https://discord.com/api/webhooks/...' npm run supabase:discord-webhook
# Or Dashboard → Project Settings → Edge Functions → Secrets → DISCORD_WEBHOOK_URL
