# Internet Archive logged-in cookie values (paste from DevTools Application → Cookies for archive.org).
# Never commit real values. Prefer a JSON pool for rotation (single line):

# IA_COOKIE_POOL=[{"user":"URL_ENCODED_logged-in-user","sig":"logged-in-sig"},...]
# Optional obfuscated form: base64(JSON string), optionally encoded multiple rounds.
# IA_COOKIE_POOL_B64=
# IA_COOKIE_B64_ROUNDS=1

# Or a single account:
# IA_LOGGED_IN_USER=
# IA_LOGGED_IN_SIG=

# Optional IA map builder:
# IA_MAP_LIMIT_IDENTIFIERS=3
# IA_MAP_FILTER_TO_MASTER=1

# Download proxy (Cloudflare Worker). vite.config.ts defaults to the deployed worker if unset.
# Override here or set GitHub Actions variable VITE_DOWNLOAD_PROXY_ORIGIN for Pages builds.
# VITE_DOWNLOAD_PROXY_ORIGIN=https://xbx-place-download-proxy.youraccount.workers.dev

# Supabase Auth (publishable keys only — safe for the static frontend):
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Download proxy only (never expose in Vite). Paste the full key on its own line — no inline comments.
# SUPABASE_SERVICE_ROLE_KEY=
